# Environment Configuration

# Platform
PLATFORM=jetson  # Options: jetson, desktop, rpi

# Camera Settings
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30

# Model Settings
MODEL_PATH=data/model/yolov3_train_class2_final.weights.h5
YOLO_CONFIDENCE=0.5
YOLO_IOU=0.3

# API Settings
OPENFOODFACTS_TIMEOUT=5
API_CACHE_ENABLED=true
API_CACHE_TTL=3600

# Training Settings
BATCH_SIZE=32
LEARNING_RATE=0.001
EPOCHS=100

# Paths
DATASET_PATH=data/curated_dataset/
TRAIN_TFRECORD=data/train.tf_record
VAL_TFRECORD=data/val.tf_record
TEST_TFRECORD=data/test.tf_record
CHECKPOINT_DIR=checkpoints/
LOG_DIR=logs/

# Docker
DOCKER_GPU_ENABLED=true
